# Service GPIO machine à fumée (Raspberry Pi) — chargé par systemd via EnvironmentFile.
# Copier en .env et remplir les valeurs. NE PAS committer le .env rempli.
# Format systemd : KEY=value, sans "export", sans guillemets autour des valeurs.

# Broche du relais (BCM) et port d'écoute HTTP local.
SMOKE_GPIO_PIN=17
SMOKE_PORT=8787

# Secret partagé : DOIT être identique à SMOKE_SERVICE_TOKEN côté compagnon (NAS).
SMOKE_TOKEN=

# Bornes de durée d'impulsion (ms) — garde-fou anti-blocage du relais.
SMOKE_MIN_MS=50
SMOKE_MAX_MS=1500
SMOKE_DEFAULT_MS=300
