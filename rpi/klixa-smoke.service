[Unit]
Description=Klixa - Service GPIO machine a fumee
After=network.target

[Service]
Type=simple
# Adapter l'utilisateur et le chemin selon l'installation
User=rpi_user
WorkingDirectory=/home/rpi_user/klixa-smoke
EnvironmentFile=/home/rpi_user/klixa-smoke/.env
ExecStart=/usr/bin/python3 /home/rpi_user/klixa-smoke/smoke_service.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
