[Unit]
Description=Klixa - Service GPIO machine a fumee
After=network.target

[Service]
Type=simple
# Adapter l'utilisateur et le chemin selon l'installation
User=pi
WorkingDirectory=/home/pi/klixa-smoke
EnvironmentFile=/home/pi/klixa-smoke/.env
ExecStart=/usr/bin/python3 /home/pi/klixa-smoke/smoke_service.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
