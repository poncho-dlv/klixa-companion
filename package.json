{
  "name": "klixa-companion",
  "version": "5.0.1",
  "description": "Agent local (hub) reliant les intégrations locales (machine à fumée, Hue, lampes SmallRig, Streamer.bot) au serveur Klixa cloud via une connexion sortante.",
  "author": "Klixa",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/poncho-dlv/klixa-companion.git"
  },
  "homepage": "https://github.com/poncho-dlv/klixa-companion#readme",
  "bugs": "https://github.com/poncho-dlv/klixa-companion/issues",
  "type": "module",
  "main": "desktop/main.js",
  "scripts": {
    "start": "node src/index.js",
    "desktop": "electron desktop/main.js",
    "predist:win": "npm run build:webbluetooth:win",
    "dist:win": "electron-builder --win nsis --publish never",
    "build:webbluetooth:win": "node scripts/build-webbluetooth-win.mjs",
    "diagnose:smallrig:gatt": "node scripts/diagnose-smallrig-gatt.mjs",
    "test": "node --test",
    "smoke:webbluetooth": "node scripts/smoke-webbluetooth.mjs",
    "smoke:webbluetooth:packaged": "node scripts/smoke-packaged-webbluetooth.mjs",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@streamerbot/client": "^1.12.2",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.6.2",
    "obs-websocket-js": "^5.0.8",
    "patch-package": "^8.0.1",
    "webbluetooth": "3.7.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "live.klixa.companion",
    "productName": "Klixa Companion",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "src/**/*",
      "package.json",
      "!node_modules/webbluetooth/build{,/**/*}",
      "!node_modules/webbluetooth/SimpleBLE{,/**/*}",
      "!node_modules/webbluetooth/src{,/**/*}",
      "!node_modules/webbluetooth/test{,/**/*}",
      "!node_modules/webbluetooth/docs{,/**/*}",
      "!node_modules/webbluetooth/examples{,/**/*}",
      "!node_modules/webbluetooth/lib{,/**/*}",
      "!node_modules/webbluetooth/prebuilds/simpleble-*{,/**/*}"
    ],
    "asar": {
      "smartUnpack": false
    },
    "asarUnpack": [
      "node_modules/webbluetooth/prebuilds/klixa-simpleble-win32-x64/*.node"
    ],
    "publish": {
      "provider": "github",
      "owner": "poncho-dlv",
      "repo": "klixa-companion"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Klixa-Companion-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
