{
  "name": "klixa-companion",
  "version": "0.3.2",
  "description": "Agent local (hub) reliant les intégrations locales (machine à fumée, Hue, Streamer.bot) au serveur Klixa cloud via une connexion sortante.",
  "author": "Klixa",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/poncho-dlv/klixa-companion.git"
  },
  "homepage": "https://github.com/poncho-dlv/klixa-companion#readme",
  "bugs": "https://github.com/poncho-dlv/klixa-companion/issues",
  "type": "module",
  "main": "desktop/main.js",
  "scripts": {
    "start": "node src/index.js",
    "desktop": "electron desktop/main.js",
    "dist:win": "electron-builder --win nsis --publish never",
    "test": "node --test"
  },
  "dependencies": {
    "@streamerbot/client": "^1.12.2",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.6.2",
    "obs-websocket-js": "^5.0.8",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "live.klixa.companion",
    "productName": "Klixa Companion",
    "directories": { "output": "release" },
    "files": ["desktop/**/*", "src/**/*", "package.json"],
    "asar": true,
    "publish": { "provider": "github", "owner": "poncho-dlv", "repo": "klixa-companion" },
    "win": { "target": ["nsis"], "artifactName": "Klixa-Companion-Setup-${version}.${ext}" },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
