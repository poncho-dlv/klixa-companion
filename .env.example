# --- Liaison vers le serveur Klixa (cloud) — connexion SORTANTE uniquement ---
# Laisser CLOUD_WS_URL vide pour tourner en "mode local seul" (test sans cloud).
CLOUD_WS_URL=wss://klixa.live/companion/ws
# Token dédié, généré côté Klixa (Paramètres → Compagnon → Régénérer). NE PAS
# réutiliser le token overlay. Le serveur en déduit le tenant : pas besoin d'autre id.
COMPANION_TOKEN=

# Reconnexion (backoff exponentiel borné)
CLOUD_RECONNECT_MIN_MS=1000
CLOUD_RECONNECT_MAX_MS=30000
# Ping WebSocket ; absence de pong au cycle suivant = reconnexion.
CLOUD_HEARTBEAT_MS=30000

# --- Serveur HTTP local du compagnon (santé + déclenchement de test) ---
PORT=8786
# 127.0.0.1 = machine locale uniquement ; 0.0.0.0 = LAN/conteneur.
COMPANION_HOST=0.0.0.0
# Obligatoire en production lorsque COMPANION_HOST n'est pas une adresse loopback.
# Envoyer ce secret dans le header x-companion-token pour POST /commands/*.
COMPANION_LOCAL_TOKEN=

# --- Intégration machine à fumée (service GPIO sur le Raspberry Pi) ---
SMOKE_ENABLED=true
SMOKE_SERVICE_URL=http://192.168.1.50:8787
# Secret partagé : DOIT être identique à SMOKE_TOKEN côté Raspberry Pi. Sans lui,
# n'importe quel appareil du LAN pourrait déclencher la machine à fumée.
# Générer : python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SMOKE_SERVICE_TOKEN=
SMOKE_DEFAULT_MS=300
SMOKE_MIN_MS=50
SMOKE_MAX_MS=1500

# --- Intégration Philips Hue NATIVE (le compagnon parle au bridge sur le LAN) ---
HUE_ENABLED=true
# IP locale du bridge (app Hue → Paramètres → Mon bridge). En usage desktop, laisser vide
# ici et configurer/appairer depuis l'app Klixa Companion (section Philips Hue) : Klixa
# (cloud) ne connaît jamais cette IP, même transitoirement.
HUE_BRIDGE_IP=192.168.1.40
# Clé d'application (hue-application-key), obtenue en appairant (bouton physique du bridge).
# Jamais fournie par le cloud.
HUE_APP_KEY=
HUE_MAX_LIGHTS=50
HUE_CONCURRENCY=5

# --- Intégration OBS NATIVE (obs-websocket — le compagnon parle à OBS sur le LAN) ---
# Activer dans OBS : Outils → WebSocket Server Settings. Mettre l'IP LAN du PC OBS
# (pas 127.0.0.1 : le compagnon tourne sur le NAS, pas sur le PC OBS).
OBS_ENABLED=true
OBS_WS_URL=ws://192.168.1.X:4455
OBS_WS_PASSWORD=
# (overlayBase n'est pas configuré ici : il est toujours fourni par le serveur.)

# --- Pont Streamer.bot (le compagnon héberge la connexion SB, sur le LAN avec SB) ---
# IP LAN du PC qui fait tourner Streamer.bot (pas 127.0.0.1 si le compagnon est sur le NAS).
SB_ENABLED=true
SB_HOST=192.168.1.X
SB_PORT=8080
SB_ENDPOINT=/
SB_PASSWORD=
SB_SCHEME=ws
