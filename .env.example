# --- Liaison vers le serveur Klixa (cloud) — connexion SORTANTE uniquement ---
# Laisser CLOUD_WS_URL vide pour tourner en "mode local seul" (test sans cloud).
CLOUD_WS_URL=wss://klixa.live/companion/ws
# Token dédié, généré côté Klixa (Paramètres → Compagnon → Régénérer). NE PAS
# réutiliser le token overlay. Le serveur en déduit le tenant : pas besoin d'autre id.
COMPANION_TOKEN=

# Reconnexion (backoff exponentiel borné)
CLOUD_RECONNECT_MIN_MS=1000
CLOUD_RECONNECT_MAX_MS=30000

# --- Serveur HTTP local du compagnon (santé + déclenchement de test) ---
PORT=8786
# Optionnel : protège POST /commands/* sur le LAN (header x-companion-token)
COMPANION_LOCAL_TOKEN=

# --- Intégration machine à fumée (service GPIO sur le Raspberry Pi) ---
SMOKE_ENABLED=true
SMOKE_SERVICE_URL=http://192.168.1.50:8787
SMOKE_SERVICE_TOKEN=
SMOKE_DEFAULT_MS=300
SMOKE_MIN_MS=50
SMOKE_MAX_MS=1500

# --- Intégration Philips Hue NATIVE (le compagnon parle au bridge sur le LAN) ---
HUE_ENABLED=true
# IP locale du bridge (app Hue → Paramètres → Mon bridge)
HUE_BRIDGE_IP=192.168.1.40
# Clé d'application (hue-application-key). Surchargeable par le payload envoyé par le cloud ;
# laisser vide si la config vient du serveur (page admin Hue).
HUE_APP_KEY=

# --- Intégration OBS NATIVE (obs-websocket — le compagnon parle à OBS sur le LAN) ---
# Activer dans OBS : Outils → WebSocket Server Settings. Mettre l'IP LAN du PC OBS
# (pas 127.0.0.1 : le compagnon tourne sur le NAS, pas sur le PC OBS).
OBS_ENABLED=true
OBS_WS_URL=ws://192.168.1.X:4455
OBS_WS_PASSWORD=
# (overlayBase n'est pas configuré ici : il est toujours fourni par le serveur.)
